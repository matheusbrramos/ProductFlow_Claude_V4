# Variáveis de ambiente do PM Builder
# Copie para .env e preencha os valores

# Diretório raiz do projeto (padrão: diretório atual)
# PROJECT_ROOT=/caminho/do/projeto

# Modelo padrão para codegen (padrão: claude-sonnet-4-6)
# DEFAULT_MODEL=claude-sonnet-4-6

# Idioma da entrevista (padrão: pt-BR)
# INTERVIEW_LANG=pt-BR

# Número máximo de perguntas na entrevista (padrão: 8)
# MAX_INTERVIEW_QUESTIONS=8
